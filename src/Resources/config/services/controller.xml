<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Setono\SyliusCompletenessPlugin\Controller\Admin\BulkRecalculateAction"
                 public="true">
            <argument type="service" id="setono_sylius_completeness.command_bus"/>
            <argument type="service" id="security.csrf.token_manager"/>
            <argument type="service" id="router"/>
        </service>

        <service id="Setono\SyliusCompletenessPlugin\Controller\Admin\RecalculateProductAction"
                 public="true">
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Provider\ProductProvider"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Updater\ProductCompletenessUpdater"/>
            <argument type="service" id="security.csrf.token_manager"/>
            <argument type="service" id="router"/>
        </service>

        <service id="Setono\SyliusCompletenessPlugin\Controller\Admin\DashboardAction"
                 public="true">
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Provider\CompletenessDashboardProvider"/>
            <argument type="service" id="twig"/>
        </service>

        <service id="Setono\SyliusCompletenessPlugin\Controller\Admin\RecalculateAllAction"
                 public="true">
            <argument type="service" id="setono_sylius_completeness.command_bus"/>
            <argument type="service" id="security.csrf.token_manager"/>
            <argument type="service" id="router"/>
        </service>

        <service id="Setono\SyliusCompletenessPlugin\Controller\Admin\PreviewAction"
                 public="true">
            <argument type="service" id="form.factory"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Calculator\CompletenessCalculator"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Preview\ScratchpadEvaluator"/>
            <argument type="service" id="sylius.repository.channel"/>
            <argument type="service" id="sylius.repository.locale"/>
            <argument type="service" id="twig"/>
        </service>
    </services>
</container>
