<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="setono_sylius_completeness.controller.admin.bulk_recalculate"
                 class="Setono\SyliusCompletenessPlugin\Controller\Admin\BulkRecalculateAction"
                 public="true">
            <argument type="service" id="setono_sylius_completeness.command_bus"/>
            <argument type="service" id="security.csrf.token_manager"/>
            <argument type="service" id="router"/>
        </service>

        <service id="setono_sylius_completeness.controller.admin.recalculate_product"
                 class="Setono\SyliusCompletenessPlugin\Controller\Admin\RecalculateProductAction"
                 public="true">
            <argument type="service" id="setono_sylius_completeness.provider.product"/>
            <argument type="service" id="setono_sylius_completeness.updater"/>
            <argument type="service" id="security.csrf.token_manager"/>
            <argument type="service" id="router"/>
        </service>

        <service id="setono_sylius_completeness.controller.admin.preview"
                 class="Setono\SyliusCompletenessPlugin\Controller\Admin\PreviewAction"
                 public="true">
            <argument type="service" id="form.factory"/>
            <argument type="service" id="setono_sylius_completeness.calculator"/>
            <argument type="service" id="setono_sylius_completeness.preview.scratchpad_evaluator"/>
            <argument type="service" id="sylius.repository.channel"/>
            <argument type="service" id="sylius.repository.locale"/>
            <argument type="service" id="twig"/>
        </service>
    </services>
</container>
