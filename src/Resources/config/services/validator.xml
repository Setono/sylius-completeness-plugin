<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="setono_sylius_completeness.validator.registered_checker_type"
                 class="Setono\SyliusCompletenessPlugin\Validator\Constraints\RegisteredCheckerTypeValidator">
            <argument type="service" id="setono_sylius_completeness.registry.checker"/>
            <tag name="validator.constraint_validator"/>
        </service>

        <service id="setono_sylius_completeness.validator.valid_expression"
                 class="Setono\SyliusCompletenessPlugin\Validator\Constraints\ValidExpressionValidator">
            <argument type="service" id="setono_sylius_completeness.expression_validator"/>
            <tag name="validator.constraint_validator"/>
        </service>

        <service id="setono_sylius_completeness.validator.expression_required_when_expression_type"
                 class="Setono\SyliusCompletenessPlugin\Validator\Constraints\ExpressionRequiredWhenExpressionTypeValidator">
            <tag name="validator.constraint_validator"/>
        </service>
    </services>
</container>
