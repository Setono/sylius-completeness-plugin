<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Setono\SyliusCompletenessPlugin\Rollup\WeightedAverageRollupStrategy">
            <tag name="setono_sylius_completeness.rollup_strategy"/>
        </service>

        <service id="Setono\SyliusCompletenessPlugin\Rollup\MinimumRollupStrategy">
            <tag name="setono_sylius_completeness.rollup_strategy"/>
        </service>

        <service id="Setono\SyliusCompletenessPlugin\Rollup\DefaultChannelRollupStrategy">
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Rollup\WeightedAverageRollupStrategy"/>
            <argument>%setono_sylius_completeness.default_channel_code%</argument>
            <tag name="setono_sylius_completeness.rollup_strategy"/>
        </service>

        <service id="Setono\SyliusCompletenessPlugin\Rollup\Rollup">
            <!-- the name => strategy locator is injected as argument 0 by RegisterRollupStrategiesPass -->
            <argument type="collection"/>
            <argument>%setono_sylius_completeness.rollup_strategy%</argument>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Rollup\RollupInterface"
                 alias="Setono\SyliusCompletenessPlugin\Rollup\Rollup"/>
    </services>
</container>
