<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Setono\SyliusCompletenessPlugin\Twig\CompletenessDisplayExtension"
                 class="Setono\SyliusCompletenessPlugin\Twig\CompletenessDisplayExtension">
            <tag name="twig.extension"/>
        </service>

        <service id="Setono\SyliusCompletenessPlugin\Twig\CompletenessDisplayRuntime"
                 class="Setono\SyliusCompletenessPlugin\Twig\CompletenessDisplayRuntime">
            <argument type="service" id="setono_sylius_completeness.repository.completeness_rule"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Calculator\RuleWeightResolver"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Rubric\RubricVersionManager"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\ViewModel\CompletenessPanelFactory"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Expression\ExpressionFunctionNameProvider"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Expression\ExpressionFunctionDocumentationProvider"/>
            <argument>%setono_sylius_completeness.checkers%</argument>
            <argument>%setono_sylius_completeness.default_ready_threshold%</argument>
            <argument>%setono_sylius_completeness.amber_band%</argument>
            <tag name="twig.runtime"/>
            <tag name="kernel.reset" method="reset"/>
        </service>
    </services>
</container>
