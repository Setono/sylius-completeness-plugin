            <argument type="service" id="setono_sylius_completeness.clock"/>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Recalculation\RecalculationLockManagerInterface"
                 alias="setono_sylius_completeness.recalculation_lock_manager"/>
    </services>
</container>
