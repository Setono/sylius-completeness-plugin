<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="Setono\SyliusCompletenessPlugin\Provider\ProductIdsProvider">
            <argument type="service" id="doctrine"/>
            <argument>%sylius.model.product.class%</argument>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Provider\ProductIdsProviderInterface"
                 alias="Setono\SyliusCompletenessPlugin\Provider\ProductIdsProvider"/>

        <service id="Setono\SyliusCompletenessPlugin\Provider\ProductProvider">
            <argument type="service" id="doctrine"/>
            <argument>%sylius.model.product.class%</argument>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Provider\ProductProviderInterface"
                 alias="Setono\SyliusCompletenessPlugin\Provider\ProductProvider"/>

        <service id="Setono\SyliusCompletenessPlugin\Rubric\RubricVersionManager">
            <argument type="service" id="setono_sylius_completeness.repository.rubric_version"/>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Rubric\RubricVersionManagerInterface"
                 alias="Setono\SyliusCompletenessPlugin\Rubric\RubricVersionManager"/>

        <service id="Setono\SyliusCompletenessPlugin\Provider\CompletenessContextProvider">
            <argument type="service" id="setono_sylius_completeness.repository.context"/>
            <tag name="kernel.reset" method="reset"/>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Provider\CompletenessContextProviderInterface"
                 alias="Setono\SyliusCompletenessPlugin\Provider\CompletenessContextProvider"/>

        <service id="Setono\SyliusCompletenessPlugin\Resolver\ThresholdResolver">
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Provider\CompletenessContextProvider"/>
            <argument>%setono_sylius_completeness.default_ready_threshold%</argument>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Resolver\ThresholdResolverInterface"
                 alias="Setono\SyliusCompletenessPlugin\Resolver\ThresholdResolver"/>

        <service id="Setono\SyliusCompletenessPlugin\Provider\CompletenessDashboardProvider">
            <argument type="service" id="doctrine.orm.entity_manager"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Rubric\RubricVersionManager"/>
            <argument>%sylius.model.product.class%</argument>
            <argument>%setono_sylius_completeness.default_ready_threshold%</argument>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Provider\CompletenessDashboardProviderInterface"
                 alias="Setono\SyliusCompletenessPlugin\Provider\CompletenessDashboardProvider"/>
    </services>
</container>
