<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="setono_sylius_completeness.provider.product_ids"
                 class="Setono\SyliusCompletenessPlugin\Provider\ProductIdsProvider">
            <argument type="service" id="doctrine"/>
            <argument>%sylius.model.product.class%</argument>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Provider\ProductIdsProviderInterface"
                 alias="setono_sylius_completeness.provider.product_ids"/>

        <service id="setono_sylius_completeness.provider.product"
                 class="Setono\SyliusCompletenessPlugin\Provider\ProductProvider">
            <argument type="service" id="doctrine"/>
            <argument>%sylius.model.product.class%</argument>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Provider\ProductProviderInterface"
                 alias="setono_sylius_completeness.provider.product"/>

        <service id="setono_sylius_completeness.rubric_version_manager"
                 class="Setono\SyliusCompletenessPlugin\Rubric\RubricVersionManager">
            <argument type="service" id="doctrine"/>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Rubric\RubricVersionManagerInterface"
                 alias="setono_sylius_completeness.rubric_version_manager"/>

        <service id="setono_sylius_completeness.provider.completeness_context"
                 class="Setono\SyliusCompletenessPlugin\Provider\CompletenessContextProvider">
            <argument type="service" id="setono_sylius_completeness.repository.context"/>
            <tag name="kernel.reset" method="reset"/>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Provider\CompletenessContextProviderInterface"
                 alias="setono_sylius_completeness.provider.completeness_context"/>

        <service id="setono_sylius_completeness.resolver.threshold"
                 class="Setono\SyliusCompletenessPlugin\Resolver\ThresholdResolver">
            <argument type="service" id="setono_sylius_completeness.provider.completeness_context"/>
            <argument>%setono_sylius_completeness.default_ready_threshold%</argument>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Resolver\ThresholdResolverInterface"
                 alias="setono_sylius_completeness.resolver.threshold"/>

        <service id="setono_sylius_completeness.provider.completeness_dashboard"
                 class="Setono\SyliusCompletenessPlugin\Provider\CompletenessDashboardProvider">
            <argument type="service" id="doctrine.orm.entity_manager"/>
            <argument type="service" id="setono_sylius_completeness.rubric_version_manager"/>
            <argument>%sylius.model.product.class%</argument>
            <argument>%setono_sylius_completeness.default_ready_threshold%</argument>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Provider\CompletenessDashboardProviderInterface"
                 alias="setono_sylius_completeness.provider.completeness_dashboard"/>
    </services>
</container>
