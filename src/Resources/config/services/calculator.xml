<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="setono_sylius_completeness.clock" class="Symfony\Component\Clock\Clock"/>

        <service id="Setono\SyliusCompletenessPlugin\Calculator\RuleApplicabilityChecker"
                 class="Setono\SyliusCompletenessPlugin\Calculator\RuleApplicabilityChecker">
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Expression\ExpressionEvaluator"/>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Calculator\RuleApplicabilityCheckerInterface"
                 alias="Setono\SyliusCompletenessPlugin\Calculator\RuleApplicabilityChecker"/>

        <service id="Setono\SyliusCompletenessPlugin\Calculator\RuleWeightResolver"
                 class="Setono\SyliusCompletenessPlugin\Calculator\RuleWeightResolver">
            <argument>%setono_sylius_completeness.weight_tiers%</argument>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Calculator\RuleWeightResolverInterface"
                 alias="Setono\SyliusCompletenessPlugin\Calculator\RuleWeightResolver"/>

        <service id="Setono\SyliusCompletenessPlugin\Calculator\ContextInitializer"
                 class="Setono\SyliusCompletenessPlugin\Calculator\ContextInitializer">
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Context\CalculationContext"/>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Calculator\ContextInitializerInterface"
                 alias="Setono\SyliusCompletenessPlugin\Calculator\ContextInitializer"/>

        <service id="Setono\SyliusCompletenessPlugin\Calculator\CompletenessCalculator"
                 class="Setono\SyliusCompletenessPlugin\Calculator\CompletenessCalculator">
            <argument type="service" id="setono_sylius_completeness.repository.completeness_rule"/>
            <argument type="service" id="setono_sylius_completeness.registry.checker"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Calculator\RuleApplicabilityChecker"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Calculator\RuleWeightResolver"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Calculator\ContextInitializer"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Rollup\Rollup"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Provider\CompletenessContextProvider"/>
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Rubric\RubricVersionManager"/>
            <argument type="service" id="setono_sylius_completeness.clock"/>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Calculator\CompletenessCalculatorInterface"
                 alias="Setono\SyliusCompletenessPlugin\Calculator\CompletenessCalculator"/>

        <service id="Setono\SyliusCompletenessPlugin\Updater\ProductCompletenessUpdater"
                 class="Setono\SyliusCompletenessPlugin\Updater\ProductCompletenessUpdater">
            <argument type="service" id="Setono\SyliusCompletenessPlugin\Calculator\CompletenessCalculator"/>
            <argument type="service" id="setono_sylius_completeness.factory.product_completeness"/>
            <argument type="service" id="doctrine"/>
            <argument type="service" id="event_dispatcher"/>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\Updater\ProductCompletenessUpdaterInterface"
                 alias="Setono\SyliusCompletenessPlugin\Updater\ProductCompletenessUpdater"/>
    </services>
</container>
