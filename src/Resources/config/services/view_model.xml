<?xml version="1.0" encoding="UTF-8"?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <service id="setono_sylius_completeness.factory.completeness_panel"
                 class="Setono\SyliusCompletenessPlugin\ViewModel\CompletenessPanelFactory">
            <argument type="service" id="setono_sylius_completeness.resolver.threshold"/>
            <argument type="service" id="setono_sylius_completeness.provider.context_settings"/>
            <argument type="service" id="setono_sylius_completeness.rubric_version_manager"/>
            <argument>%setono_sylius_completeness.amber_band%</argument>
        </service>
        <service id="Setono\SyliusCompletenessPlugin\ViewModel\CompletenessPanelFactoryInterface"
                 alias="setono_sylius_completeness.factory.completeness_panel"/>
    </services>
</container>
