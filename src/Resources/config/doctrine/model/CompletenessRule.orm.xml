<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="Setono\SyliusCompletenessPlugin\Model\CompletenessRule" table="setono_sylius_completeness__completeness_rule">
        <indexes>
            <index columns="enabled"/>
        </indexes>

        <id name="id" type="integer">
            <generator strategy="AUTO"/>
        </id>

        <field name="code" type="string" unique="true"/>
        <field name="label" type="string"/>
        <field name="group" column="group_name" type="string" nullable="true"/>
        <field name="type" type="string"/>
        <field name="configuration" type="json"/>
        <field name="weightTier" column="weight_tier" type="string" length="32"/>
        <field name="customWeight" column="custom_weight" type="float" nullable="true"/>
        <field name="enabled" type="boolean"/>
        <field name="channelCodes" column="channel_codes" type="json"/>
        <field name="localeCodes" column="locale_codes" type="json"/>
        <field name="taxonCodes" column="taxon_codes" type="json"/>
        <field name="condition" column="gate_condition" type="text" nullable="true"/>
        <field name="position" type="integer"/>
    </entity>
</doctrine-mapping>
