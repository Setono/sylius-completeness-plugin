<?xml version="1.0" encoding="UTF-8"?>
<doctrine-mapping xmlns="http://doctrine-project.org/schemas/orm/doctrine-mapping"
                  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
                  xsi:schemaLocation="http://doctrine-project.org/schemas/orm/doctrine-mapping https://www.doctrine-project.org/schemas/orm/doctrine-mapping.xsd">
    <entity name="Setono\SyliusCompletenessPlugin\Model\CompletenessContextSetting" table="setono_sylius_completeness__context_setting">
        <unique-constraints>
            <unique-constraint columns="channel_code,locale_code" name="setono_sylius_completeness__context_setting_uniq"/>
        </unique-constraints>

        <id name="id" type="integer">
            <generator strategy="AUTO"/>
        </id>

        <field name="channelCode" column="channel_code" type="string"/>
        <field name="localeCode" column="locale_code" type="string" length="12"/>
        <field name="threshold" type="smallint" nullable="true"/>
        <field name="rollupWeight" column="rollup_weight" type="float"/>
    </entity>
</doctrine-mapping>
