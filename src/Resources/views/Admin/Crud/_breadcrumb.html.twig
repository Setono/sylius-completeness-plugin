{% import '@SyliusAdmin/Macro/breadcrumb.html.twig' as breadcrumb %}

{# shared by the rule + context CRUD; inserts a Completeness (dashboard) crumb after
   Administration, then adapts the trailing crumbs to the index / new / edit action #}
{% set breadcrumbLabel = configuration.vars.breadcrumb|default(metadata.applicationName ~ '.ui.' ~ metadata.pluralName) %}

{% set crumbs = [
    { label: 'sylius.ui.administration'|trans, url: path('sylius_admin_dashboard') },
    { label: 'setono_sylius_completeness.ui.completeness'|trans, url: path('setono_sylius_completeness_admin_dashboard') },
] %}

{% if resource is defined and resource is not null %}
    {% set index_url = path(
        configuration.vars.index.route.name|default(configuration.getRouteName('index')),
        configuration.vars.index.route.parameters|default(configuration.vars.route.parameters|default({}))
    ) %}
    {% set crumbs = crumbs|merge([{ label: breadcrumbLabel|trans, url: index_url }]) %}
    {% if resource.id|default(null) %}
        {% set crumbs = crumbs|merge([
            { label: resource.name|default(resource.code|default(resource.id)) },
            { label: 'sylius.ui.edit'|trans },
        ]) %}
    {% else %}
        {% set crumbs = crumbs|merge([{ label: 'sylius.ui.new'|trans }]) %}
    {% endif %}
{% else %}
    {% set crumbs = crumbs|merge([{ label: breadcrumbLabel|trans }]) %}
{% endif %}

{{ breadcrumb.crumble(crumbs) }}
