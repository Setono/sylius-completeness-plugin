{# Progressive enhancement: turn every `textarea[data-ssc-expression]` into a CodeMirror editor with
   ExpressionLanguage syntax highlighting and autocompletion of the in-scope variables, the registered
   expression functions (with their signature and description) and the most useful
   `product.`/`channel.`/`locale.` getters. CodeMirror is loaded from a versioned, SRI-pinned CDN so the
   plugin needs no asset build; if it fails to load the plain textareas keep working. #}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.css"
      integrity="sha384-zaeBlB/vwYsDRSlFajnDd7OydJ0cWk+c2OWybl3eSUf6hW2EbhlCsQPqKr3gkznT" crossorigin="anonymous" referrerpolicy="no-referrer">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/addon/hint/show-hint.min.css"
      integrity="sha384-TU/qRI67N04B589luYdn1ZMRIGgJic3GB1WsvLJTRh92VO26vpxI4dCKiDtsR4fw" crossorigin="anonymous" referrerpolicy="no-referrer">
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/codemirror.min.js"
        integrity="sha384-ZYmwuq4n2gOcNxMSiJ6jyTj+BbIrilr7p6dlq6q5nmSWKmsH9UU4K1qqjycMkfmR" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/addon/mode/simple.min.js"
        integrity="sha384-5+aYjV0V2W3IwhAYp/9WOrGMv1TaYkCjnkkW7Hv3yJQo28MergRCSRaUIUzDUs2J" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/codemirror/5.65.16/addon/hint/show-hint.min.js"
        integrity="sha384-qCnKPgNYgVO8RO19jShRRAfU75+KVnN1cQy+8CPX/TTwJsUEJ/EpnwKx2UOyLx8c" crossorigin="anonymous" referrerpolicy="no-referrer"></script>

<style>
    .CodeMirror {
        border: 1px solid rgba(34, 36, 38, .15);
        border-radius: .28571429rem;
        height: auto;
        min-height: 8rem;
        font-family: monospace;
        font-size: .95em;
        background: #fff;
    }
    .CodeMirror-focused { border-color: #85b7d9; }
    .CodeMirror-hints {
        z-index: 1002;
        max-width: 34rem;
        font-family: inherit;
        padding: 0;
    }
    .CodeMirror-hint { padding: 5px 9px; border-bottom: 1px solid rgba(0, 0, 0, .04); }
    .ssc-hint-sig { font-family: monospace; font-weight: 600; }
    .ssc-hint-desc { font-size: .82em; color: #6b7280; white-space: normal; }
    li.CodeMirror-hint-active .ssc-hint-desc { color: rgba(255, 255, 255, .9); }
</style>

<script>
    (function () {
        var VARIABLES = {
            product: 'The product being scored.',
            channel: 'The channel of the evaluated context.',
            locale: 'The locale of the evaluated context.',
            channelCode: 'The channel code (string) of the evaluated context.',
            localeCode: 'The locale code (string) of the evaluated context.'
        };
        var FUNCTIONS = {{ ssc_expression_functions()|json_encode|raw }};
        var DOCS = {{ ssc_expression_function_docs()|json_encode|raw }};

        // curated getters for the object variables, so `product.` (etc.) autocompletes
        var MEMBERS = {
            product: [
                'getName()', 'getDescription()', 'getShortDescription()', 'getMetaKeywords()',
                'getMetaDescription()', 'getSlug()', 'getCode()', 'getTranslation()', 'getMainTaxon()',
                'getChannels()', 'getVariants()', 'getEnabledVariants()', 'getImages()', 'getAttributes()',
                'isEnabled()', 'isSimple()', 'isConfigurable()'
            ],
            channel: ['getCode()', 'getName()', 'getLocales()', 'getBaseCurrency()'],
            locale: ['getCode()', 'getName()']
        };

        function makeEntry(name, signature, description) {
            return {
                text: name,
                displayText: signature,
                render: function (element) {
                    var sig = document.createElement('div');
                    sig.className = 'ssc-hint-sig';
                    sig.textContent = signature;
                    element.appendChild(sig);

                    if (description) {
                        var desc = document.createElement('div');
                        desc.className = 'ssc-hint-desc';
                        desc.textContent = description;
                        element.appendChild(desc);
                    }
                }
            };
        }

        var TOP_LEVEL = [];
        Object.keys(VARIABLES).forEach(function (name) {
            TOP_LEVEL.push(makeEntry(name, name, VARIABLES[name]));
        });
        FUNCTIONS.forEach(function (name) {
            var doc = DOCS[name];
            TOP_LEVEL.push(makeEntry(name, doc ? doc.signature : name + '(…)', doc ? doc.description : ''));
        });

        function escapeRegExp(value) {
            return value.replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
        }

        function defineMode() {
            if (typeof CodeMirror.defineSimpleMode !== 'function' || CodeMirror.modes.sscExpression) {
                return CodeMirror.modes.sscExpression ? 'sscExpression' : 'null';
            }

            var functionRegex = FUNCTIONS.length
                ? new RegExp('\\b(?:' + FUNCTIONS.map(escapeRegExp).join('|') + ')\\b(?=\\s*\\()')
                : /a^/; // matches nothing when there are no functions

            CodeMirror.defineSimpleMode('sscExpression', {
                start: [
                    { regex: /"(?:[^\\"]|\\.)*"?/, token: 'string' },
                    { regex: /'(?:[^\\']|\\.)*'?/, token: 'string' },
                    { regex: /\b(?:true|false|null)\b/, token: 'atom' },
                    { regex: /\b(?:not|and|or|in|matches|starts with|ends with|contains)\b/, token: 'keyword' },
                    { regex: functionRegex, token: 'def' },
                    { regex: /\b(?:product|channel|locale|channelCode|localeCode)\b/, token: 'variable-2' },
                    { regex: /-?(?:\d+\.\d*|\.\d+|\d+)/, token: 'number' },
                    { regex: /[-+*/%=<>!~?:&|]+/, token: 'operator' },
                    { regex: /[A-Za-z_$][\w$]*/, token: 'variable' }
                ],
                meta: { electricInput: false }
            });

            return 'sscExpression';
        }

        function hint(cm) {
            var cursor = cm.getCursor();
            var before = cm.getLine(cursor.line).slice(0, cursor.ch);

            // the identifier currently being typed (may be empty), and the text preceding it
            var partial = (before.match(/[A-Za-z_$][\w$]*$/) || [''])[0];
            var head = before.slice(0, before.length - partial.length);

            var completion = { from: CodeMirror.Pos(cursor.line, cursor.ch - partial.length), to: CodeMirror.Pos(cursor.line, cursor.ch) };

            // member access `<variable>.<partial>` -> suggest that variable's getters
            var member = head.match(/([A-Za-z_$][\w$]*)\.\s*$/);
            if (member) {
                if (!MEMBERS[member[1]]) {
                    // a dot after something we have no members for (e.g. `product.getName().`): offer nothing
                    return null;
                }

                completion.list = MEMBERS[member[1]].filter(function (item) {
                    return partial === '' || item.toLowerCase().indexOf(partial.toLowerCase()) === 0;
                });

                return completion;
            }

            // a dot preceding the cursor that is not a known member access -> offer nothing rather than
            // dumping the whole top-level list
            if (/\.\s*$/.test(head)) {
                return null;
            }

            // top level: variables + functions (with signature and description)
            completion.list = TOP_LEVEL.filter(function (entry) {
                return partial === '' || entry.text.toLowerCase().indexOf(partial.toLowerCase()) === 0;
            });

            return completion;
        }

        function enhance() {
            if (typeof window.CodeMirror === 'undefined') {
                return;
            }

            var mode = defineMode();

            document.querySelectorAll('textarea[data-ssc-expression]:not([data-ssc-editor-ready])').forEach(function (textarea) {
                textarea.setAttribute('data-ssc-editor-ready', '1');

                var editor = CodeMirror.fromTextArea(textarea, {
                    mode: mode,
                    lineWrapping: true,
                    viewportMargin: Infinity,
                    extraKeys: { 'Ctrl-Space': 'autocomplete' }
                });
                editor.setOption('hintOptions', { completeSingle: false, hint: hint });

                editor.on('inputRead', function (cm, change) {
                    // trigger on identifier characters and on the member-access dot
                    if (/[\w.]$/.test(change.text[0] || '')) {
                        cm.showHint({ completeSingle: false });
                    }
                });
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', enhance);
        } else {
            enhance();
        }
    })();
</script>
