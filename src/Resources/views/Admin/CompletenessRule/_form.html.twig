<div class="ui two column stackable grid">
    <div class="column">
        <h4 class="ui dividing header">{{ 'setono_sylius_completeness.ui.rule'|trans }}</h4>
        {{ form_row(form.type) }}
        {# a hidden, escaped configuration prototype per checker type; handlePrototypes swaps the right
           one into the container client-side when the checker changes (no page reload). The custom
           expression editor is the "expression" checker's configuration, so it appears the same way #}
        {% for type, configurationPrototype in form.vars.prototypes %}
            <div id="{{ form.type.vars.id }}_{{ type }}" data-container="#ssc-checker-configuration"
                 data-prototype="{{ form_widget(configurationPrototype)|e('html_attr') }}"></div>
        {% endfor %}
        <div id="ssc-checker-configuration">
            {% if form.configuration is defined %}
                {{ form_widget(form.configuration) }}
            {% endif %}
        </div>

        <h4 class="ui dividing header" style="margin-top: 1.5em;">{{ 'setono_sylius_completeness.ui.details'|trans }}</h4>
        {{ form_row(form.label) }}
        {# the code sits right under the label: generated from it and read-only on create (unlock to edit),
           disabled/immutable once the rule exists - the same idea as Sylius' code and slug fields #}
        <div class="field">
            {{ form_label(form.code) }}
            {% if form.code.vars.disabled %}
                {{ form_widget(form.code) }}
            {% else %}
                <div class="ui action input">
                    {{ form_widget(form.code) }}
                    <button type="button" class="ui icon button ssc-code-toggle" tabindex="-1"
                            title="{{ 'setono_sylius_completeness.ui.edit_code'|trans }}">
                        <i class="lock icon"></i>
                    </button>
                </div>
            {% endif %}
            {{ form_help(form.code) }}
            {{ form_errors(form.code) }}
        </div>
        {{ form_row(form.group) }}
        {{ form_row(form.weightTier) }}
        {{ form_row(form.position) }}
        {{ form_row(form.enabled) }}

        {% if form.customWeight is defined %}
            <div class="ui styled fluid accordion" style="margin-top: 1em;">
                <div class="title">
                    <i class="dropdown icon"></i>
                    {{ 'setono_sylius_completeness.ui.advanced'|trans }}
                </div>
                <div class="content">
                    {{ form_row(form.customWeight) }}
                </div>
            </div>
        {% endif %}
    </div>
    <div class="column">
        <h4 class="ui dividing header">{{ 'setono_sylius_completeness.ui.scope'|trans }}</h4>
        {# rendered field-by-field: Sylius' expanded-choice widget already prints the help, so using
           form_row here would duplicate it - render the label + widget (which includes the help) instead #}
        <div class="field">
            {{ form_label(form.channelCodes) }}
            {{ form_widget(form.channelCodes) }}
            {{ form_errors(form.channelCodes) }}
        </div>
        {{ form_row(form.localeCodes) }}
        {{ form_row(form.taxonCodes) }}
        {{ form_row(form.condition) }}

        <div class="ui styled fluid accordion" style="margin-top: 1em;">
            <div class="title">
                <i class="dropdown icon"></i>
                {{ 'setono_sylius_completeness.ui.function_reference'|trans }}
            </div>
            <div class="content">
                {% include '@SetonoSyliusCompletenessPlugin/Admin/_functionReference.html.twig' %}
            </div>
        </div>
    </div>
</div>

{% include '@SetonoSyliusCompletenessPlugin/Admin/_expressionEditor.html.twig' %}

<script>
    (function () {
        // bind Sylius' client-side prototype swap to the checker select, so its configuration fields
        // update when the checker changes. The admin JS provides jQuery + the handlePrototypes plugin
        function bind() {
            var $ = window.jQuery;
            if (!$ || !$.fn.handlePrototypes) {
                return false;
            }

            var select = $('#{{ form.type.vars.id }}');
            if (select.length > 0) {
                select.handlePrototypes({ containerSelector: '#ssc-checker-configuration' });

                // after the configuration is swapped, enhance the custom-expression editor if it appeared
                select.on('change', function () {
                    if (typeof window.sscEnhanceExpressionEditors === 'function') {
                        window.sscEnhanceExpressionEditors();
                    }
                });
            }

            return true;
        }

        if (!bind()) {
            var attempts = 0;
            var timer = setInterval(function () {
                if (bind() || ++attempts > 50) {
                    clearInterval(timer);
                }
            }, 100);
        }
    })();

    (function () {
        // on create, keep the (read-only) code in sync with the label until the user unlocks it to type
        // a custom one - the same live-generation idea as Sylius' slug field
        var code = document.querySelector('input[data-ssc-code]');
        var label = document.querySelector('#{{ form.label.vars.id }}');
        if (!code || !label) {
            return;
        }

        function slugify(value) {
            return value
                .normalize('NFKD').replace(/[\u0300-\u036f]/g, '')
                .toLowerCase()
                .replace(/[^a-z0-9]+/g, '_')
                .replace(/^_+|_+$/g, '');
        }

        var timer;
        label.addEventListener('input', function () {
            clearTimeout(timer);
            timer = setTimeout(function () {
                if (code.hasAttribute('readonly')) {
                    code.value = slugify(label.value);
                }
            }, 250);
        });

        var toggle = document.querySelector('.ssc-code-toggle');
        if (toggle) {
            toggle.addEventListener('click', function () {
                var icon = toggle.querySelector('i');
                if (code.hasAttribute('readonly')) {
                    code.removeAttribute('readonly');
                    if (icon) { icon.className = 'unlock icon'; }
                    code.focus();
                } else {
                    code.setAttribute('readonly', 'readonly');
                    if (icon) { icon.className = 'lock icon'; }
                    code.value = slugify(label.value);
                }
            });
        }
    })();
</script>
