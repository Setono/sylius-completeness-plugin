parameters:
    level: max

    paths:
        - src
        - tests

    excludePaths:
        - tests/Application/*

    bootstrapFiles:
        - vendor/autoload.php

    # Symfony Configuration
    symfony:
        consoleApplicationLoader: tests/PHPStan/console_application.php

    # Doctrine Configuration
    doctrine:
        repositoryClass: Doctrine\ORM\EntityRepository
        objectManagerLoader: tests/PHPStan/object_manager.php

    reportUnmatchedIgnoredErrors: false
    treatPhpDocTypesAsCertain: false

    # Our entity convention is "nullable PHP property, NOT NULL DB column" — the value is populated
    # (form, factory, calculator) before flush. The plugin also types relation properties with
    # interfaces (ProductInterface) while phpstan-doctrine resolves relations to the concrete
    # app-level entity class. phpstan-doctrine's rules cannot express either split, so we silence
    # them for the model layer only.
    ignoreErrors:
        -
            identifier: doctrine.columnType
            path: src/Model/*
        -
            identifier: doctrine.associationType
            path: src/Model/*
