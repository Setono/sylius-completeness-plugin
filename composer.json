{
    "name": "setono/sylius-completeness-plugin",
    "description": "Sylius plugin that computes a weighted, per-channel/per-locale enrichment completeness percentage for products.",
    "license": "MIT",
    "type": "sylius-plugin",
    "keywords": [
        "sylius",
        "sylius-plugin",
        "completeness",
        "enrichment",
        "pim"
    ],
    "require": {
        "php": ">=8.1",
        "doctrine/collections": "^1.6 || ^2.0",
        "doctrine/dbal": "^3.0",
        "doctrine/orm": "^2.14",
        "doctrine/persistence": "^2.1 || ^3.0",
        "psr/clock": "^1.0",
        "psr/event-dispatcher": "^1.0",
        "psr/log": "^1.1 || ^2.0 || ^3.0",
        "sylius/core": "^1.0",
        "sylius/core-bundle": "^1.0",
        "sylius/locale": "^1.0",
        "sylius/product": "^1.0",
        "sylius/registry": "^1.0",
        "sylius/resource-bundle": "^1.6",
        "sylius/ui-bundle": "^1.0",
        "symfony/clock": "^6.4",
        "symfony/config": "^6.4",
        "symfony/console": "^6.4",
        "symfony/dependency-injection": "^6.4",
        "symfony/expression-language": "^6.4",
        "symfony/form": "^6.4",
        "symfony/messenger": "^6.4",
        "symfony/options-resolver": "^6.4",
        "symfony/service-contracts": "^2.5 || ^3.0",
        "symfony/string": "^6.4",
        "symfony/validator": "^6.4",
        "twig/twig": "^2.14 || ^3.0"
    },
    "require-dev": {
        "api-platform/core": "^2.7.16",
        "babdev/pagerfanta-bundle": "^3.8",
        "behat/behat": "^3.14",
        "doctrine/doctrine-bundle": "^2.11",
        "jms/serializer-bundle": "^4.2",
        "lexik/jwt-authentication-bundle": "^2.17",
        "setono/sylius-plugin-pack": "~1.14.1",
        "shipmonk/composer-dependency-analyser": "^1.6",
        "sylius/sylius": "^1.14",
        "sylius-labs/polyfill-symfony-security": "^1.1.2",
        "symfony/browser-kit": "^6.4",
        "symfony/css-selector": "^6.4",
        "symfony/debug-bundle": "^6.4",
        "symfony/dotenv": "^6.4",
        "symfony/intl": "^6.4",
        "symfony/property-info": "^6.4",
        "symfony/serializer": "^6.4",
        "symfony/web-profiler-bundle": "^6.4",
        "symfony/webpack-encore-bundle": "^1.17.2",
        "willdurand/negotiation": "^3.1"
    },
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Setono\\SyliusCompletenessPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Setono\\SyliusCompletenessPlugin\\Tests\\": "tests/"
        },
        "classmap": [
            "tests/Application/Kernel.php"
        ]
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "infection/extension-installer": true,
            "phpstan/extension-installer": true,
            "symfony/thanks": false
        },
        "audit": {
            "block-insecure": false
        },
        "sort-packages": true
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "check-style": "ecs check",
        "fix-style": "ecs check --fix",
        "phpunit": "phpunit"
    }
}
